@model IEnumerable<HealthcareViewModel>
@{ ViewData["Title"] = "Healthcare Visits"; }

<div class="d-flex justify-content-between mb-3">
    <h5>Healthcare Visits</h5>
    <a asp-action="Create" class="btn btn-warning"><i class="bi bi-plus"></i> Add Visit</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Hospital</th>
                    <th>Doctor</th>
                    <th>Diagnosis</th>
                    <th>Date</th>
                    <th>Fee</th>
                    <th>Notes</th>
                    <th width="80">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.HospitalName</td>
                            <td>@item.DoctorName</td>
                            <td>@item.Diagnosis</td>
                            <td>@item.VisitDate.ToString("dd MMM yyyy")</td>
                            <td>&#8377; @item.ConsultationFee.ToString("N2")</td>
                            <td>@item.Notes</td>
                            <td>
                                <form asp-action="Delete" asp-route-id="@item.HealthcareId" method="post" class="d-inline" onsubmit="return confirm('Delete?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">No healthcare visits found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
