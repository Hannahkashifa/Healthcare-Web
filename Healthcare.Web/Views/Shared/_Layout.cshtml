<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PHET</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
</head>
<body>
    <div class="toast-container" id="toastContainer"></div>

    <button class="hamburger-btn" onclick="toggleSidebar()">
        <i class="bi bi-list"></i>
    </button>
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

    <div class="container-fluid">
        <div class="row">
            <div class="col-md-2 sidebar d-none d-md-block" id="sidebarMain">
                <div class="brand">
                    <i class="bi bi-heart-pulse"></i> PHET
                </div>
                <a asp-controller="Dashboard" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="bi bi-grid-1x2"></i> Dashboard
                </a>
                <a asp-controller="Income" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Income" ? "active" : "")">
                    <i class="bi bi-wallet2"></i> Income
                </a>
                <a asp-controller="Expense" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Expense" ? "active" : "")">
                    <i class="bi bi-receipt"></i> Expenses
                </a>
                <a asp-controller="Healthcare" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Healthcare" ? "active" : "")">
                    <i class="bi bi-hospital"></i> Healthcare
                </a>
                <a asp-controller="Medicine" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Medicine" ? "active" : "")">
                    <i class="bi bi-capsule"></i> Medicine
                </a>
                <hr />
                <a asp-controller="Profile" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Profile" ? "active" : "")">
                    <i class="bi bi-person"></i> Profile
                </a>
                <a asp-controller="Account" asp-action="Logout" class="text-danger">
                    <i class="bi bi-box-arrow-left"></i> Logout
                </a>
            </div>
            <div class="col-md-10 p-4 main-content">
                <div class="header-bar">
                    <div class="header-left">
                        <h4>@ViewData["Title"]</h4>
                    </div>
                    <div class="header-right">
                        <div class="notification-bell" onclick="event.stopPropagation(); toggleNotifications()">
                            <i class="bi bi-bell"></i>
                            <span class="badge-count" id="notifCount" style="display:none">0</span>
                            <div class="notification-dropdown" id="notifDropdown" onclick="event.stopPropagation()">
                                <div class="notification-item" style="border-bottom:1px solid var(--border)">
                                    <strong style="color:var(--text-primary);font-size:0.85rem">Notifications</strong>
                                </div>
                                <div id="notifList">
                                    <div class="notification-empty">Loading...</div>
                                </div>
                            </div>
                        </div>

                        <div class="theme-switcher">
                            <button class="theme-btn" id="themeToggle">
                                <i class="bi bi-palette"></i>
                                <span id="themeToggleText">Light</span>
                                <i class="bi bi-chevron-down"></i>
                            </button>
                            <div class="theme-dropdown" id="themeDropdown">
                                <button class="theme-option" data-theme="light">
                                    <span class="theme-dot light"></span> Light
                                </button>
                                <button class="theme-option" data-theme="dark">
                                    <span class="theme-dot dark"></span> Dark
                                </button>
                                <button class="theme-option" data-theme="ocean">
                                    <span class="theme-dot ocean"></span> Ocean
                                </button>
                                <button class="theme-option" data-theme="rose">
                                    <span class="theme-dot rose"></span> Rose
                                </button>
                            </div>
                        </div>

                        <span class="text-muted">
                            <i class="bi bi-person-circle"></i> @Context.Session.GetString("UserName")
                        </span>
                    </div>
                </div>
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var ctrl = '@ViewContext.RouteData.Values["controller"]';
            var sidebar = document.getElementById('sidebarMain');
            if (ctrl === 'Account') {
                if (sidebar) sidebar.style.display = 'none';
            }
            loadNotifications();
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
