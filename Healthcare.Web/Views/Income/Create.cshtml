@model AddIncomeViewModel
@{ ViewData["Title"] = "Add Income";
   var sources = new List<string> { "Salary", "Freelance", "Business", "Investment", "Rental", "Interest", "Gift", "Refund", "Other" }; }

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5><i class="bi bi-wallet2 text-success me-2"></i>New Income</h5>
                <hr />
                <div asp-validation-summary="All" class="text-danger mb-3"></div>
                <form asp-action="Create" method="post">
                    <div class="mb-3">
                        <label asp-for="Source" class="form-label"></label>
                        <select asp-for="Source" class="form-select">
                            <option value="">-- Select Source --</option>
                            @foreach (var src in sources)
                            {
                                <option value="@src">@src</option>
                            }
                        </select>
                        <span asp-validation-for="Source" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Amount" class="form-label"></label>
                        <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0" placeholder="0.00" />
                        <span asp-validation-for="Amount" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="IncomeDate" class="form-label"></label>
                        <input asp-for="IncomeDate" class="form-control" type="date" />
                        <span asp-validation-for="IncomeDate" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Optional notes..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-success"><i class="bi bi-check-lg"></i> Save</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
