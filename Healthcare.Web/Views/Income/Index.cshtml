@model IEnumerable<IncomeViewModel>
@{ ViewData["Title"] = "Income"; }

<div class="d-flex justify-content-between mb-3">
    <h5>All Income</h5>
    <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus"></i> Add Income</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Source</th>
                    <th>Amount</th>
                    <th>Date</th>
                    <th>Description</th>
                    <th width="160">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="badge bg-success">@item.Source</span></td>
                            <td>&#8377; @item.Amount.ToString("N2")</td>
                            <td>@item.IncomeDate.ToString("dd MMM yyyy")</td>
                            <td>@item.Description</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.IncomeId" class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></a>
                                <form asp-action="Delete" asp-route-id="@item.IncomeId" method="post" class="d-inline" onsubmit="return confirm('Delete this income?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">No income records found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
