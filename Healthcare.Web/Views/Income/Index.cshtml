@model IEnumerable<IncomeViewModel>
@{ ViewData["Title"] = "Income"; }

<div class="d-flex justify-content-between mb-3">
    <h5>All Income</h5>
    <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus"></i> Add Income</a>
</div>

<div class="filter-bar">
    <div class="filter-group">
        <label>Search</label>
        <input type="text" class="form-control" placeholder="Search..." id="searchInput" onkeyup="filterTable('searchInput', 'incomeTable')">
    </div>
    <div class="filter-group">
        <label>From Date</label>
        <input type="date" class="form-control" id="dateFrom">
    </div>
    <div class="filter-group">
        <label>To Date</label>
        <input type="date" class="form-control" id="dateTo">
    </div>
    <div class="filter-group" style="flex:0">
        <label>&nbsp;</label>
        <div class="d-flex gap-2">
            <button class="export-btn" onclick="exportToPDF('Report')"><i class="bi bi-file-earmark-pdf"></i> Export</button>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0" id="incomeTable">
            <thead class="table-dark">
                <tr>
                    <th onclick="sortTable('incomeTable', 0, 'text')">Source</th>
                    <th onclick="sortTable('incomeTable', 1, 'num')">Amount</th>
                    <th onclick="sortTable('incomeTable', 2, 'date')">Date</th>
                    <th>Description</th>
                    <th width="160">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="badge bg-success">@item.Source</span></td>
                            <td>&#8377; @item.Amount.ToString("N2")</td>
                            <td data-date="@item.IncomeDate.ToString("yyyy-MM-dd")">@item.IncomeDate.ToString("dd MMM yyyy")</td>
                            <td>@item.Description</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.IncomeId" class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></a>
                                <form asp-action="Delete" asp-route-id="@item.IncomeId" method="post" class="d-inline" onsubmit="return confirm('Delete this income?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">No income records found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
