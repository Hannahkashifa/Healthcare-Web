@model AddIncomeViewModel
@{ ViewData["Title"] = "Edit Income"; }

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5>Edit Income</h5>
                <hr />
                <div asp-validation-summary="All" class="text-danger mb-3"></div>
                <form asp-action="Edit" asp-route-id="@ViewBag.Id" method="post">
                    <div class="mb-3">
                        <label asp-for="Source" class="form-label"></label>
                        <input asp-for="Source" class="form-control" />
                        <span asp-validation-for="Source" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Amount" class="form-label"></label>
                        <input asp-for="Amount" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="Amount" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="IncomeDate" class="form-label"></label>
                        <input asp-for="IncomeDate" class="form-control" type="date" />
                        <span asp-validation-for="IncomeDate" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    </div>
                    <button type="submit" class="btn btn-warning"><i class="bi bi-check-lg"></i> Update</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
