@model ProfileViewModel
@{ ViewData["Title"] = "My Profile"; }

<div class="row justify-content-center">
    <div class="col-12 col-lg-8">
        <div class="profile-card">
            <div class="profile-header">
                <div class="profile-avatar-wrapper" onclick="document.getElementById('profilePhotoInput').click()" title="Change photo">
                    @if (!string.IsNullOrEmpty(Model.ProfilePicture))
                    {
                        <img src="https://localhost:7230@(Model.ProfilePicture)" alt="Profile" class="profile-avatar-img" />
                    }
                    else
                    {
                        <div class="profile-avatar-text">
                            @(string.IsNullOrEmpty(Model.FullName) ? "U" : Model.FullName[0].ToString().ToUpper())
                        </div>
                    }
                    <div class="profile-avatar-overlay">
                        <i class="bi bi-camera-fill"></i>
                    </div>
                </div>
                <input type="file" id="profilePhotoInput" accept="image/*" style="display:none" onchange="uploadProfilePicture(this)" />
                <h4 class="fw-bold mb-1">@Model.FullName</h4>
                <p style="color:rgba(255,255,255,0.7);margin:0;font-size:0.9rem">@Model.Email</p>
            </div>
            <div class="profile-body">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show">
                        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show">
                        <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <h6 class="fw-bold text-uppercase mb-3" style="color:var(--text-secondary);font-size:0.75rem;letter-spacing:1px">Personal Information</h6>

                <form asp-controller="Profile" asp-action="Update" method="post" data-loading>
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label">Full Name</label>
                            <input asp-for="FullName" class="form-control" placeholder="Enter full name" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Email</label>
                            <input asp-for="Email" class="form-control" readonly style="opacity:0.7" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Phone Number</label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="Enter phone number" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Date of Birth</label>
                            <input asp-for="DateOfBirth" type="date" class="form-control" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Gender</label>
                            <select asp-for="Gender" class="form-select">
                                <option value="">Select...</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Member Since</label>
                            <div class="form-control" style="opacity:0.7;cursor:default">
                                <i class="bi bi-calendar3 me-1"></i>@Model.CreatedDate.ToString("dd MMMM yyyy")
                            </div>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary mt-4">
                        <i class="bi bi-check-lg me-1"></i> Save Changes
                    </button>
                </form>

                <div class="password-section">
                    <h6 class="fw-bold text-uppercase mb-3" style="color:var(--text-secondary);font-size:0.75rem;letter-spacing:1px">
                        <i class="bi bi-shield-lock me-1"></i> Change Password
                    </h6>
                    <form asp-controller="Profile" asp-action="ChangePassword" method="post" data-loading>
                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label class="form-label">Current Password</label>
                                <input type="password" name="currentPassword" class="form-control" placeholder="Enter current password" required />
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">New Password</label>
                                <input type="password" name="newPassword" class="form-control" placeholder="Enter new password" minlength="6" required />
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">Confirm New Password</label>
                                <input type="password" name="confirmNewPassword" class="form-control" placeholder="Re-enter new password" minlength="6" required />
                            </div>
                        </div>
                        <button type="submit" class="btn btn-warning mt-4">
                            <i class="bi bi-key me-1"></i> Change Password
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function uploadProfilePicture(input) {
    var file = input.files[0];
    if (!file) return;

    if (file.size > 5 * 1024 * 1024) {
        showToast('Image must be under 5MB.', 'danger');
        return;
    }

    var formData = new FormData();
    formData.append('file', file);

    showLoading('Uploading...');

    fetch('https://localhost:7230/api/Users/profile-picture', {
        method: 'POST',
        headers: {
            'Authorization': 'Bearer @Context.Session.GetString("Token")'
        },
        body: formData,
        credentials: 'omit'
    })
    .then(function(r) {
        hideLoading();
        if (!r.ok) return r.text().then(function(t) { throw new Error(t); });
        return r.json();
    })
    .then(function(data) {
        showToast('Profile picture updated!', 'success');
        var img = document.querySelector('.profile-avatar-img');
        var txt = document.querySelector('.profile-avatar-text');
        if (img) {
            img.src = 'https://localhost:7230' + data.profilePicture + '?t=' + Date.now();
        } else if (txt) {
            var wrapper = document.querySelector('.profile-avatar-wrapper');
            var newImg = document.createElement('img');
            newImg.src = 'https://localhost:7230' + data.profilePicture;
            newImg.alt = 'Profile';
            newImg.className = 'profile-avatar-img';
            txt.replaceWith(newImg);
        }
    })
    .catch(function(err) {
        hideLoading();
        showToast(err.message || 'Failed to upload image.', 'danger');
    });
}
</script>
