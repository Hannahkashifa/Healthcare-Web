@model IEnumerable<ExpenseViewModel>
@{ ViewData["Title"] = "Expenses"; }

<div class="d-flex justify-content-between mb-3">
    <h5>All Expenses</h5>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus"></i> Add Expense</a>
</div>

<div class="filter-bar">
    <div class="filter-group">
        <label>Search</label>
        <input type="text" class="form-control" placeholder="Search..." id="searchInput" onkeyup="filterTable('searchInput', 'expenseTable')">
    </div>
    <div class="filter-group">
        <label>From Date</label>
        <input type="date" class="form-control" id="dateFrom">
    </div>
    <div class="filter-group">
        <label>To Date</label>
        <input type="date" class="form-control" id="dateTo">
    </div>
    <div class="filter-group" style="flex:0">
        <label>&nbsp;</label>
        <div class="d-flex gap-2">
            <button class="export-btn" onclick="exportToPDF('Report')"><i class="bi bi-file-earmark-pdf"></i> Export</button>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0" id="expenseTable">
            <thead class="table-dark">
                <tr>
                    <th onclick="sortTable('expenseTable', 0, 'text')">Category</th>
                    <th onclick="sortTable('expenseTable', 1, 'num')">Amount</th>
                    <th onclick="sortTable('expenseTable', 2, 'date')">Date</th>
                    <th>Description</th>
                    <th width="160">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="badge bg-secondary">@item.Category</span></td>
                            <td>&#8377; @item.Amount.ToString("N2")</td>
                            <td data-date="@item.ExpenseDate.ToString("yyyy-MM-dd")">@item.ExpenseDate.ToString("dd MMM yyyy")</td>
                            <td>@item.Description</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.ExpenseId" class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></a>
                                <form asp-action="Delete" asp-route-id="@item.ExpenseId" method="post" class="d-inline" onsubmit="return confirm('Delete this expense?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">No expenses found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
