@model IEnumerable<MedicineViewModel>
@{ ViewData["Title"] = "Medicine"; }

<div class="d-flex justify-content-between mb-3">
    <h5>All Medicines</h5>
    <a asp-action="Create" class="btn btn-info"><i class="bi bi-plus"></i> Add Medicine</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Medicine</th>
                    <th>Morning</th>
                    <th>Afternoon</th>
                    <th>Night</th>
                    <th>Duration</th>
                    <th>Price</th>
                    <th width="80">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.MedicineName</td>
                            <td>@item.MorningDose</td>
                            <td>@item.AfternoonDose</td>
                            <td>@item.NightDose</td>
                            <td>@item.DurationInDays days</td>
                            <td>&#8377; @item.Price.ToString("N2")</td>
                            <td>
                                <form asp-action="Delete" asp-route-id="@item.MedicineId" method="post" class="d-inline" onsubmit="return confirm('Delete?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">No medicines found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
