@model AddMedicineViewModel
@{ ViewData["Title"] = "Add Medicine";
   var visits = ViewBag.HealthcareVisits as List<HealthcareViewModel> ?? new List<HealthcareViewModel>(); }

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5><i class="bi bi-capsule text-info me-2"></i>New Medicine</h5>
                <hr />
                <div asp-validation-summary="All" class="text-danger mb-3"></div>
                <form asp-action="Create" method="post">
                    <div class="mb-3">
                        <label asp-for="HealthcareId" class="form-label">Healthcare Visit</label>
                        <select asp-for="HealthcareId" class="form-select">
                            <option value="">-- Select Doctor & Visit --</option>
                            @foreach (var v in visits)
                            {
                                <option value="@v.HealthcareId">
                                    Dr. @v.DoctorName - @v.HospitalName (@v.VisitDate.ToString("dd MMM yyyy"))
                                </option>
                            }
                        </select>
                        <span asp-validation-for="HealthcareId" class="text-danger"></span>
                        @if (!visits.Any())
                        {
                            <small class="text-muted">No healthcare visits found. <a asp-controller="Healthcare" asp-action="Create">Add one first</a></small>
                        }
                    </div>
                    <div class="mb-3">
                        <label asp-for="MedicineName" class="form-label"></label>
                        <input asp-for="MedicineName" class="form-control" placeholder="e.g. Paracetamol 500mg" />
                        <span asp-validation-for="MedicineName" class="text-danger"></span>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="MorningDose" class="form-label"></label>
                            <input asp-for="MorningDose" class="form-control" type="number" min="0" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="AfternoonDose" class="form-label"></label>
                            <input asp-for="AfternoonDose" class="form-control" type="number" min="0" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="NightDose" class="form-label"></label>
                            <input asp-for="NightDose" class="form-control" type="number" min="0" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="DurationInDays" class="form-label"></label>
                            <input asp-for="DurationInDays" class="form-control" type="number" min="1" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Price" class="form-label"></label>
                            <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-success"><i class="bi bi-check-lg"></i> Save</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
