@model PersonalHealthcareExpense.Web.ViewModels.Account.ForgotPasswordViewModel
@{ ViewData["Title"] = "Forgot Password"; Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password - Healthcare Tracker</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            min-height: 100vh; display: flex; align-items: center; justify-content: center;
            background: linear-gradient(-45deg, #0f0c29, #302b63, #24243e, #1a1a2e);
            background-size: 400% 400%; animation: gradientShift 12s ease infinite;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        }
        @@keyframes gradientShift { 0%{background-position:0% 50%} 50%{background-position:100% 50%} 100%{background-position:0% 50%} }
        @@keyframes cardAppear { from{opacity:0;transform:translateY(40px) scale(.95)} to{opacity:1;transform:translateY(0) scale(1)} }
        @@keyframes iconFloat { 0%,100%{transform:translateY(0) scale(1)} 50%{transform:translateY(-10px) scale(1.1)} }
        @@keyframes glowPulse { 0%,100%{box-shadow:0 0 20px rgba(102,126,234,.3)} 50%{box-shadow:0 0 40px rgba(102,126,234,.6),0 0 80px rgba(118,75,162,.2)} }
        @@keyframes shimmerLine { 0%{left:-100%} 100%{left:100%} }
        @@keyframes bounceIn { 0%{opacity:0;transform:scale(.8) translateY(-10px)} 60%{transform:scale(1.03)} 100%{opacity:1;transform:scale(1)} }
        @@keyframes fadeIn { from{opacity:0} to{opacity:1} }

        .login-card {
            width: 430px; padding: 45px 40px; border-radius: 24px;
            background: rgba(255,255,255,.95); backdrop-filter: blur(20px);
            box-shadow: 0 25px 60px rgba(0,0,0,.3);
            animation: cardAppear .8s cubic-bezier(.4,0,.2,1), glowPulse 3s ease-in-out infinite;
            position: relative; overflow: hidden;
        }
        .login-card::before {
            content:''; position:absolute; top:0; left:-100%; width:100%; height:3px;
            background:linear-gradient(90deg,transparent,#667eea,#764ba2,transparent);
            animation:shimmerLine 3s ease-in-out infinite;
        }
        .icon-wrapper {
            width:80px; height:80px; margin:0 auto 20px;
            background:linear-gradient(135deg,#667eea,#764ba2);
            border-radius:50%; display:flex; align-items:center; justify-content:center;
            animation:iconFloat 3s ease-in-out infinite;
            box-shadow:0 10px 30px rgba(102,126,234,.4);
        }
        .icon-wrapper i { font-size:2.2rem; color:#fff; }
        .login-card h3 { font-weight:700; color:#1a1a2e; animation:fadeIn 1s ease .3s both; }
        .login-card p { color:#888; animation:fadeIn 1s ease .5s both; font-size:0.9rem; }
        .form-control {
            border-radius:12px; padding:12px 16px; border:2px solid #e9ecef;
            transition:all .3s ease; background:#f8f9fa;
        }
        .form-control:focus { border-color:#667eea; box-shadow:0 0 0 4px rgba(102,126,234,.15); background:#fff; transform:scale(1.02); }
        .form-label { font-weight:600; color:#495057; font-size:.9rem; }
        .btn-login {
            background:linear-gradient(135deg,#667eea,#764ba2); border:none; border-radius:12px;
            padding:13px; font-size:1.05rem; font-weight:600; color:#fff; width:100%;
            transition:all .3s cubic-bezier(.4,0,.2,1); position:relative; overflow:hidden;
        }
        .btn-login:hover { transform:translateY(-3px); box-shadow:0 12px 30px rgba(102,126,234,.5); }
        .alert-danger { border-radius:12px; border:none; background:linear-gradient(135deg,rgba(225,112,85,.1),rgba(250,177,160,.15)); color:#e17055; border-left:4px solid #e17055; animation:bounceIn .5s ease; }
        .alert-success { border-radius:12px; border:none; background:linear-gradient(135deg,rgba(0,184,148,.1),rgba(85,239,196,.15)); color:#00b894; border-left:4px solid #00b894; animation:bounceIn .5s ease; }
        .back-link { animation:fadeIn 1s ease .7s both; }
        .back-link a { color:#667eea; text-decoration:none; font-weight:600; transition:color .3s; }
        .back-link a:hover { color:#764ba2; text-decoration:underline; }

        .particles { position:fixed; top:0; left:0; width:100%; height:100%; pointer-events:none; overflow:hidden; z-index:0; }
        .particle { position:absolute; width:6px; height:6px; background:rgba(102,126,234,.3); border-radius:50%; animation:floatParticle linear infinite; }
        .particle:nth-child(1){left:10%;animation-duration:8s} .particle:nth-child(2){left:25%;animation-duration:12s;animation-delay:1s;width:4px;height:4px}
        .particle:nth-child(3){left:40%;animation-duration:10s;animation-delay:2s;width:8px;height:8px} .particle:nth-child(4){left:55%;animation-duration:14s;animation-delay:.5s}
        .particle:nth-child(5){left:70%;animation-duration:9s;animation-delay:3s;width:5px;height:5px} .particle:nth-child(6){left:85%;animation-duration:11s;animation-delay:1.5s;width:7px;height:7px}
        @@keyframes floatParticle { 0%{transform:translateY(100vh) rotate(0);opacity:0} 10%{opacity:.6} 90%{opacity:.6} 100%{transform:translateY(-10vh) rotate(720deg);opacity:0} }
    </style>
</head>
<body>
    <div class="particles">
        <div class="particle"></div><div class="particle"></div><div class="particle"></div>
        <div class="particle"></div><div class="particle"></div><div class="particle"></div>
    </div>

    <div class="login-card" style="position:relative;z-index:1;">
        <div class="text-center mb-4">
            <div class="icon-wrapper">
                <i class="bi bi-key"></i>
            </div>
            <h3>Forgot Password?</h3>
            <p class="mt-2">Enter your email and we'll send you a reset link.</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }
        @if (ViewBag.Success != null)
        {
            <div class="alert alert-success">@ViewBag.Success</div>
        }

        <form asp-action="ForgotPassword" method="post">
            <div class="mb-4">
                <label class="form-label">Email Address</label>
                <input asp-for="Email" type="email" class="form-control" placeholder="you@example.com" required />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <button type="submit" class="btn-login">
                <i class="bi bi-send me-2"></i>Send Reset Link
            </button>
        </form>
        <div class="text-center mt-4 back-link">
            <a asp-action="Login"><i class="bi bi-arrow-left me-1"></i>Back to Login</a>
        </div>
    </div>
</body>
</html>
