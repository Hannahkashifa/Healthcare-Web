@model PersonalHealthcareExpense.Web.ViewModels.Account.LoginViewModel
@{ ViewData["Title"] = "Login"; Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Healthcare Tracker</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            min-height: 100vh; display: flex; align-items: center; justify-content: center;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
            background: var(--bg-primary);
            transition: background 0.4s ease;
        }

        .login-bg {
            position: fixed; inset: 0; z-index: 0;
            background: linear-gradient(-45deg, #0f0c29, #302b63, #24243e, #1a1a2e);
            background-size: 400% 400%; animation: gradientShift 12s ease infinite;
            transition: opacity 0.4s ease;
        }

        [data-theme="dark"] .login-bg { background: linear-gradient(-45deg, #0a0a0a, #1a1a2e, #0f172a, #020617); }
        [data-theme="ocean"] .login-bg { background: linear-gradient(-45deg, #0c4a6e, #134e4a, #0e7490, #164e63); }
        [data-theme="rose"] .login-bg { background: linear-gradient(-45deg, #4c0519, #881337, #9f1239, #6b0f1a); }

        @@keyframes gradientShift { 0%{background-position:0% 50%} 50%{background-position:100% 50%} 100%{background-position:0% 50%} }
        @@keyframes cardAppear { from{opacity:0;transform:translateY(40px) scale(.95)} to{opacity:1;transform:translateY(0) scale(1)} }
        @@keyframes iconFloat { 0%,100%{transform:translateY(0) scale(1)} 50%{transform:translateY(-10px) scale(1.1)} }
        @@keyframes glowPulse { 0%,100%{box-shadow:0 0 20px rgba(102,126,234,.3)} 50%{box-shadow:0 0 40px rgba(102,126,234,.6),0 0 80px rgba(118,75,162,.2)} }
        @@keyframes shimmerLine { 0%{left:-100%} 100%{left:100%} }
        @@keyframes bounceIn { 0%{opacity:0;transform:scale(.8) translateY(-10px)} 60%{transform:scale(1.03)} 100%{opacity:1;transform:scale(1)} }
        @@keyframes fadeIn { from{opacity:0} to{opacity:1} }

        .login-card {
            width: 430px; padding: 45px 40px; border-radius: 24px;
            background: var(--bg-glass); backdrop-filter: blur(20px);
            box-shadow: 0 25px 60px rgba(0,0,0,.3);
            animation: cardAppear .8s cubic-bezier(.4,0,.2,1), glowPulse 3s ease-in-out infinite;
            position: relative; overflow: hidden; z-index: 1;
            border: 1px solid var(--border);
            transition: background 0.4s ease, border-color 0.4s ease;
        }
        .login-card::before {
            content:''; position:absolute; top:0; left:-100%; width:100%; height:3px;
            background:linear-gradient(90deg,transparent,var(--accent),transparent);
            animation:shimmerLine 3s ease-in-out infinite;
        }
        .icon-wrapper {
            width:80px; height:80px; margin:0 auto 20px;
            background:linear-gradient(135deg,#667eea,#764ba2);
            border-radius:50%; display:flex; align-items:center; justify-content:center;
            animation:iconFloat 3s ease-in-out infinite;
            box-shadow:0 10px 30px rgba(102,126,234,.4);
        }
        .icon-wrapper i { font-size:2.2rem; color:#fff; }
        .login-card h3 { font-weight:700; color:var(--text-primary); animation:fadeIn 1s ease .3s both; transition:color 0.4s; }
        .login-card p { color:var(--text-secondary); animation:fadeIn 1s ease .5s both; font-size:0.9rem; transition:color 0.4s; }
        .form-control {
            border-radius:12px; padding:12px 16px; border:2px solid var(--input-border);
            transition:all .3s ease; background:var(--input-bg); color:var(--text-primary);
        }
        .form-control:focus { border-color:var(--accent); box-shadow:0 0 0 4px var(--accent-light); background:var(--bg-secondary); transform:scale(1.02); }
        .form-control::placeholder { color:var(--text-muted); }
        .form-label { font-weight:600; color:var(--text-secondary); font-size:.9rem; transition:color 0.4s; }
        .btn-login {
            background:var(--accent); border:none; border-radius:12px;
            padding:13px; font-size:1.05rem; font-weight:600; color:#fff; width:100%;
            transition:all .3s cubic-bezier(.4,0,.2,1); position:relative; overflow:hidden;
        }
        .btn-login:hover { transform:translateY(-3px); box-shadow:0 12px 30px var(--accent-glow); background:var(--accent-hover); }
        .alert-danger { border-radius:12px; border:none; background:rgba(255,59,48,0.1); color:var(--danger); border-left:4px solid var(--danger); animation:bounceIn .5s ease; }
        .alert-success { border-radius:12px; border:none; background:rgba(48,209,88,0.1); color:var(--success); border-left:4px solid var(--success); animation:bounceIn .5s ease; }
        .register-link { animation:fadeIn 1s ease .7s both; }
        .register-link a { color:var(--accent); text-decoration:none; font-weight:600; transition:color .3s; }
        .register-link a:hover { text-decoration:underline; }
        .forgot-link { animation:fadeIn 1s ease .6s both; margin-bottom:8px; text-align:right; }
        .forgot-link a { color:var(--accent); text-decoration:none; font-size:0.85rem; font-weight:600; transition:color .3s; }
        .forgot-link a:hover { text-decoration:underline; }

        .particles { position:fixed; top:0; left:0; width:100%; height:100%; pointer-events:none; overflow:hidden; z-index:0; }
        .particle { position:absolute; width:6px; height:6px; background:rgba(102,126,234,.3); border-radius:50%; animation:floatParticle linear infinite; }
        .particle:nth-child(1){left:10%;animation-duration:8s} .particle:nth-child(2){left:25%;animation-duration:12s;animation-delay:1s;width:4px;height:4px}
        .particle:nth-child(3){left:40%;animation-duration:10s;animation-delay:2s;width:8px;height:8px} .particle:nth-child(4){left:55%;animation-duration:14s;animation-delay:.5s}
        .particle:nth-child(5){left:70%;animation-duration:9s;animation-delay:3s;width:5px;height:5px} .particle:nth-child(6){left:85%;animation-duration:11s;animation-delay:1.5s;width:7px;height:7px}
        .particle:nth-child(7){left:15%;animation-duration:13s;animation-delay:2.5s;width:3px;height:3px} .particle:nth-child(8){left:60%;animation-duration:7s;animation-delay:.8s;width:5px;height:5px}
        @@keyframes floatParticle { 0%{transform:translateY(100vh) rotate(0);opacity:0} 10%{opacity:.6} 90%{opacity:.6} 100%{transform:translateY(-10vh) rotate(720deg);opacity:0} }
    </style>
</head>
<body>
    <div class="login-bg"></div>
    <div class="particles">
        <div class="particle"></div><div class="particle"></div><div class="particle"></div>
        <div class="particle"></div><div class="particle"></div><div class="particle"></div>
        <div class="particle"></div><div class="particle"></div>
    </div>

    <div style="position:fixed;top:15px;right:15px;z-index:100;">
        <div class="theme-switcher">
            <button class="theme-btn" id="themeToggle">
                <i class="bi bi-palette"></i>
                <span id="themeToggleText">Light</span>
                <i class="bi bi-chevron-down"></i>
            </button>
            <div class="theme-dropdown" id="themeDropdown">
                <button class="theme-option" data-theme="light"><span class="theme-dot light"></span> Light</button>
                <button class="theme-option" data-theme="dark"><span class="theme-dot dark"></span> Dark</button>
                <button class="theme-option" data-theme="ocean"><span class="theme-dot ocean"></span> Ocean</button>
                <button class="theme-option" data-theme="rose"><span class="theme-dot rose"></span> Rose</button>
            </div>
        </div>
    </div>

    <div class="login-card">
        <div class="text-center mb-4">
            <div class="icon-wrapper">
                <i class="bi bi-heart-pulse"></i>
            </div>
            <h3>Healthcare Expense Tracker</h3>
            <p class="mt-1">Sign in to your account</p>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <form asp-action="Login" method="post">
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="mb-2">
                <label class="form-label">Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="forgot-link">
                <a asp-action="ForgotPassword">Forgot Password?</a>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn-login">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                </button>
            </div>
        </form>
        <div class="text-center mt-4 register-link">
            <span style="color:var(--text-secondary)">Don't have an account? </span>
            <a asp-action="Register">Register here</a>
        </div>
    </div>

    <script>
    (function() {
        var toggle = document.getElementById('themeToggle');
        var dropdown = document.getElementById('themeDropdown');
        var toggleText = document.getElementById('themeToggleText');

        function applyTheme(theme) {
            if (theme === 'light') {
                document.documentElement.removeAttribute('data-theme');
            } else {
                document.documentElement.setAttribute('data-theme', theme);
            }
            var labels = { light: 'Light', dark: 'Dark', ocean: 'Ocean', rose: 'Rose' };
            toggleText.textContent = labels[theme] || 'Light';
            var opts = dropdown.querySelectorAll('.theme-option');
            for (var i = 0; i < opts.length; i++) {
                if (opts[i].getAttribute('data-theme') === theme) {
                    opts[i].classList.add('active');
                } else {
                    opts[i].classList.remove('active');
                }
            }
        }

        var savedTheme = localStorage.getItem('healthcare-theme') || 'light';
        applyTheme(savedTheme);

        toggle.addEventListener('click', function(e) {
            e.stopPropagation();
            dropdown.classList.toggle('show');
        });

        var options = dropdown.querySelectorAll('.theme-option');
        for (var i = 0; i < options.length; i++) {
            options[i].addEventListener('click', function() {
                var theme = this.getAttribute('data-theme');
                localStorage.setItem('healthcare-theme', theme);
                applyTheme(theme);
                dropdown.classList.remove('show');
            });
        }

        document.addEventListener('click', function() {
            dropdown.classList.remove('show');
        });
    })();
    </script>
</body>
</html>
